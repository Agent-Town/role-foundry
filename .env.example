# Role Foundry — Environment Variables
# Copy to .env and fill in values as needed.

# ─── Web UI ──────────────────────────────────────────────────────────
WEB_PORT=8080

# ─── PostgreSQL ──────────────────────────────────────────────────────
POSTGRES_DB=rolefoundry
POSTGRES_USER=rf
POSTGRES_PASSWORD=rfdev
POSTGRES_PORT=5432

# ─── Redis ───────────────────────────────────────────────────────────
REDIS_PORT=6379

# ─── Clawith (live mode — activate with: docker compose --profile live up)
# CLAWITH_IMAGE=clawith:local   # Build from Clawith repo or use a registry image
# CLAWITH_PORT=3000
# CLAWITH_SECRET=changeme

# ─── LLM Provider Keys (for Clawith-native agents) ──────────────────
# These are NOT needed for demo mode.
# They are needed when Clawith dispatches real agent runs.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ─── ERC-8004 / Base / agent0-sdk ────────────────────────────────────
# Required for onchain ERC-8004 registration via agent0-sdk.
# None of these are needed for demo mode or local draft generation.
# For live minting, both RPC URL and registry address are REQUIRED.
# The local agent0-ts checkout does NOT reliably ship Base defaults,
# so explicit config is mandatory.
#
# Base Sepolia (review/demo default)
BASE_SEPOLIA_RPC_URL=
BASE_SEPOLIA_REGISTRY=
BASE_SEPOLIA_CHAIN_ID=84532
# BASE_SEPOLIA_SUBGRAPH_URL=    # Optional — subgraph is not required for minting
#
# Base Mainnet (explicit submission target — no claim of minting here yet)
# BASE_MAINNET_RPC_URL=
# BASE_MAINNET_REGISTRY=
# BASE_MAINNET_CHAIN_ID=8453
# BASE_MAINNET_SUBGRAPH_URL=
#
# IPFS (optional — registerHTTP works without IPFS)
# PINATA_JWT=
# IPFS_PROVIDER=pinata          # pinata | filecoinPin | node
