# Role Foundry — Environment Variables
# Copy to .env and fill in values as needed.

# ─── Web UI ──────────────────────────────────────────────────────────
WEB_PORT=8080

# ─── PostgreSQL ──────────────────────────────────────────────────────
POSTGRES_DB=rolefoundry
POSTGRES_USER=rf
POSTGRES_PASSWORD=rfdev
POSTGRES_PORT=5432

# ─── Redis ───────────────────────────────────────────────────────────
REDIS_PORT=6379

# ─── Clawith (uncomment when integrating) ────────────────────────────
# CLAWITH_PORT=3000
# CLAWITH_SECRET=changeme

# ─── LLM Provider Keys (for Clawith-native agents) ──────────────────
# These are NOT needed for demo mode.
# They are needed when Clawith dispatches real agent runs.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
