{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent.town/role-foundry/schema/frontend-product-engineer-task-packet-v1.json",
  "title": "Frontend/Product Engineer public seed task packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "role_id",
    "acceptance_test_id",
    "title",
    "phase",
    "objective",
    "context",
    "success_criteria",
    "allowed_paths",
    "blocked_paths",
    "expected_checks",
    "rubric_ref",
    "time_budget_minutes",
    "mutation_budget",
    "evidence_contract",
    "provenance",
    "packet_version",
    "student_visible",
    "teacher_only_fields_present"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "role_id": {
      "type": "string"
    },
    "acceptance_test_id": {
      "type": "string",
      "pattern": "^[A-E]\\d{3}$"
    },
    "title": {
      "type": "string"
    },
    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "index"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "index": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        }
      }
    },
    "objective": {
      "type": "string"
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "spec_refs",
        "repo_refs",
        "why_this_task_exists"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "spec_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "repo_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "why_this_task_exists": {
          "type": "string"
        }
      }
    },
    "success_criteria": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string"
      }
    },
    "allowed_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "blocked_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "blocked_scope_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "surface_extension_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "expected_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "command",
          "why"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "command": {
            "type": "string"
          },
          "why": {
            "type": "string"
          }
        }
      }
    },
    "rubric_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_id",
        "contract_path",
        "version"
      ],
      "properties": {
        "contract_id": {
          "type": "string"
        },
        "contract_path": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "time_budget_minutes": {
      "type": "integer",
      "minimum": 15
    },
    "mutation_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tracked_files_max",
        "net_lines_max",
        "overrides_default",
        "override_reason"
      ],
      "properties": {
        "tracked_files_max": {
          "type": "integer",
          "minimum": 1
        },
        "net_lines_max": {
          "type": "integer",
          "minimum": 1
        },
        "overrides_default": {
          "type": "boolean"
        },
        "override_reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "evidence_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_artifacts",
        "provenance_required",
        "student_visible_only",
        "notes"
      ],
      "properties": {
        "required_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path",
              "visibility",
              "description"
            ],
            "properties": {
              "path": {
                "type": "string"
              },
              "visibility": {
                "type": "string"
              },
              "description": {
                "type": "string"
              }
            }
          }
        },
        "provenance_required": {
          "type": "boolean"
        },
        "student_visible_only": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_kind",
        "source_ref",
        "source_record_id",
        "promotion_record_id",
        "teacher_only_inputs_used",
        "public_safe_note",
        "rf_authorship"
      ],
      "properties": {
        "source_kind": {
          "type": "string"
        },
        "source_ref": {
          "type": "string"
        },
        "source_record_id": {
          "type": "string"
        },
        "promotion_record_id": {
          "type": "string"
        },
        "teacher_only_inputs_used": {
          "type": "boolean"
        },
        "public_safe_note": {
          "type": "string"
        },
        "rf_authorship": {
          "type": "string"
        }
      }
    },
    "packet_version": {
      "type": "string"
    },
    "student_visible": {
      "type": "boolean"
    },
    "teacher_only_fields_present": {
      "type": "boolean"
    },
    "status": {
      "type": "string"
    }
  }
}
